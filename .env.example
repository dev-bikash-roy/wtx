# WordPress API Configuration
WP_API_BASE=https://wtxnews.com/wp-json/wp/v2
WP_API_KEY=your_wordpress_api_key_here

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Firebase Configuration
# Get these from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Paddle Billing
# Get from: https://vendors.paddle.com/authentication
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here
NEXT_PUBLIC_PADDLE_BASIC_PRICE_ID=pri_your_basic_price_id
NEXT_PUBLIC_PADDLE_PREMIUM_PRICE_ID=pri_your_premium_price_id
PADDLE_BASIC_PRICE_ID=pri_your_basic_price_id
PADDLE_PREMIUM_PRICE_ID=pri_your_premium_price_id
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here
